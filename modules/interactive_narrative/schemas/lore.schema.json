{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Lore",
  "type": "object",
  "required": ["lore_id", "name", "category", "summary", "historical_events", "core_beliefs", "key_figures"],
  "properties": {
    "lore_id": { "type": "string" },
    "name": { "type": "string" },
    "category": { "type": "string", "enum": ["Kingdom", "Culture", "Religion", "Guild", "Historical Event"] },
    "summary": { "type": "string" },
    "historical_events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["event_name", "date", "description"],
        "properties": {
          "event_name": { "type": "string" },
          "date": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "core_beliefs": { "type": "array", "items": { "type": "string" } },
    "key_figures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "role", "description"],
        "properties": {
          "name": { "type": "string" },
          "role": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    }
  }
}
