{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CampaignPlan",
  "type": "object",
  "required": ["theme", "story_arcs", "regions"],
  "properties": {
    "theme": { "type": "string" },
    "story_arcs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["arc_id", "title", "description", "milestone"],
        "properties": {
          "arc_id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "milestone": { "type": "string" }
        }
      }
    },
    "regions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["region_name", "quest_chains", "progression_index"],
        "properties": {
          "region_name": { "type": "string" },
          "quest_chains": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["chain_id", "title", "quests", "dependency_chain_id"],
              "properties": {
                "chain_id": { "type": "string" },
                "title": { "type": "string" },
                "quests": { "type": "array", "items": { "type": "string" } },
                "dependency_chain_id": { "type": ["string", "null"] }
              }
            }
          },
          "progression_index": { "type": "integer" }
        }
      }
    }
  }
}
