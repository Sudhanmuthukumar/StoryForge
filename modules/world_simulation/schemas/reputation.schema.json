{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Reputation",
  "type": "object",
  "properties": {
    "player": {
      "type": "object",
      "properties": {
        "factions": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "npcs": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        }
      },
      "required": ["factions", "npcs"]
    },
    "faction_relations": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": { "type": "integer" }
      }
    }
  },
  "required": ["player", "faction_relations"]
}
