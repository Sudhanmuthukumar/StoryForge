{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WorldState",
  "type": "object",
  "properties": {
    "active_events": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "event_id": { "type": "string" },
          "name": { "type": "string" },
          "region": { "type": "string" },
          "severity": { "type": "string" },
          "turns_remaining": { "type": "integer" }
        },
        "required": ["event_id", "name", "region", "severity", "turns_remaining"]
      }
    },
    "completed_quests": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "quest_id": { "type": "string" },
          "title": { "type": "string" },
          "outcome": { "type": "string" },
          "timestamp": { "type": "string" }
        },
        "required": ["quest_id", "title", "outcome", "timestamp"]
      }
    },
    "campaign_progress": {
      "type": "object",
      "properties": {
        "current_campaign_id": { "type": ["string", "null"] },
        "active_arc_id": { "type": ["string", "null"] },
        "completed_arcs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "active_regions": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["current_campaign_id", "active_arc_id", "completed_arcs", "active_regions"]
    },
    "kingdom_status": {
      "type": "object",
      "properties": {
        "kingdom_name": { "type": "string" },
        "stability": { "type": "integer" },
        "wealth": { "type": "integer" },
        "defense": { "type": "integer" },
        "ruler": { "type": "string" }
      },
      "required": ["kingdom_name", "stability", "wealth", "defense", "ruler"]
    },
    "regional_conditions": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "weather": { "type": "string" },
          "danger_level": { "type": "string" },
          "resources": { "type": "string" }
        },
        "required": ["weather", "danger_level", "resources"]
      }
    }
  },
  "required": ["active_events", "completed_quests", "campaign_progress", "kingdom_status", "regional_conditions"]
}
