{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Consequence",
  "type": "object",
  "required": ["consequence_id", "type", "description", "affected_entities", "severity", "mutations"],
  "properties": {
    "consequence_id": { "type": "string" },
    "type": { "type": "string", "enum": ["faction_conflict", "world_event", "relationship_change", "campaign_evolution"] },
    "description": { "type": "string" },
    "affected_entities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "severity": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"] },
    "mutations": {
      "type": "object",
      "properties": {
        "stability_delta": { "type": "integer" },
        "wealth_delta": { "type": "integer" },
        "defense_delta": { "type": "integer" },
        "reputation_deltas": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        }
      }
    }
  }
}
