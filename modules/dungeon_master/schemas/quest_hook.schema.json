{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Quest Hook",
  "type": "object",
  "required": ["hook_id", "title", "description", "npc_giver", "faction", "related_event_id", "objectives", "suggested_rewards"],
  "properties": {
    "hook_id": { "type": "string" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "npc_giver": { "type": "string" },
    "faction": { "type": "string" },
    "related_event_id": { "type": "string" },
    "objectives": {
      "type": "array",
      "items": { "type": "string" }
    },
    "suggested_rewards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["reward_type", "amount"],
        "properties": {
          "reward_type": { "type": "string" },
          "amount": { "type": "string" }
        }
      }
    }
  }
}
