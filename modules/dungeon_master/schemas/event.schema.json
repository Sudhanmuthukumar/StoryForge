{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Event",
  "type": "object",
  "required": ["event_id", "name", "type", "description", "severity", "turns_remaining", "affected_entities"],
  "properties": {
    "event_id": { "type": "string" },
    "name": { "type": "string" },
    "type": { "type": "string" },
    "description": { "type": "string" },
    "severity": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"] },
    "turns_remaining": { "type": "integer" },
    "affected_entities": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
